### views

# @prompt accessToken
# @prompt domainId

POST http://localhost:3000/api
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-REQUEST-TYPE: GraphQL

query fetchViews($id: ID!) {
  domain(id: $id) {
    statistics {
      id
      views(interval: DAILY, type: UNIQUE) {
        value
        count
      }
    }
  }
}

