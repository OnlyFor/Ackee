### browsers

# @prompt accessToken
# @prompt domainId

POST http://localhost:3000/api
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-REQUEST-TYPE: GraphQL

query fetchBrowsers($id: ID!) {
  domain(id: $id) {
    statistics {
      id
      browsers(sorting: TOP, type: NO_VERSION, range: LAST_6_MONTHS) {
        value
        count
        created
      }
    }
  }
}

{
  "id": "{{domainId}}"
}

